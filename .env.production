# Build-time public env for production.
# These are inlined into the client bundle by Next.js during `next build`.
# Runtime-only secrets (PAYLOAD_SECRET, DATABASE_URL, …) must NOT go here —
# they are already injected by the host (Timeweb Cloud App → envs).

NEXT_PUBLIC_SERVER_URL=https://etraproject.ru
NEXT_PUBLIC_SITE_URL=https://etraproject.ru/
PAYLOAD_PUBLIC_SERVER_URL=https://etraproject.ru/
NEXT_PUBLIC_CHAT_WS_URL=wss://chat.etraproject.ru
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=8eb80b10-32a8-4335-96f8-f071bf87c69c
